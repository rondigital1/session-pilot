# Anthropic API key for Claude Agent SDK
# Optional, but strongly recommended for live demos. Without it, the app falls back
# to template-based planning and summaries.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub personal access token for repo scanning
# Optional. Without it, GitHub signals are skipped.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SQLite database file path
DB_PATH=./session-pilot.db

# Public app URL used by same-origin API protections
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed workspace root paths
# Example: /Users/me/projects,/home/dev/repos
SESSIONPILOT_WORKSPACE_ROOTS=/path/to/your/projects
