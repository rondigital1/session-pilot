# Optional: legacy improve/session flows only.
# Not required for the repo-analysis MVP loop or Codex execution.
# ANTHROPIC_API_KEY=

# Optional: legacy GitHub scanning only.
# Not required for the repo-analysis MVP loop.
# GITHUB_TOKEN=

# SQLite database file path
DB_PATH=./session-pilot.db

# Public app URL used by same-origin API protections
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of allowed workspace root paths
# Example: /Users/you/code,/Users/you/projects
SESSIONPILOT_WORKSPACE_ROOTS=/Users/you/code

# Optional override for isolated execution worktrees
SESSIONPILOT_WORKTREE_ROOT=/Users/you/.sessionpilot/worktrees
